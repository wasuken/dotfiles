;; templates --- Tempel templates for Denote memo system

;; 8種類のメモテンプレート
;; 使い方: M-* (tempel-insert) でテンプレート名を選択
;;         Tab で次のフィールドへ移動、S-Tab で前へ戻る

markdown-mode

(checklist
 "- [ ] あすけん" n
 "	- [ ] 朝" n
 "	- [ ] 昼" n
 "	- [ ] 夜" n
 "- [ ] インフラ作業(30分程度)" n
 "- [ ] 技術記事を読む（15分）" n
 "- [ ] LeetCode一問30分制限" n
 "- [ ] ベッドメイキング" n
 "- [ ] 歯磨き" n
 "- [ ] シャワー/風呂" n
 "- [ ] 洗濯物皿洗いいずれか" n
 "- [ ] 外気を浴びる" n
 "- [ ] 日記" n
 "- [ ] 読書" n
 "- [ ] ウォーキング" n
 "- [ ] ラジオ体操" n
 "- [ ] 筋トレプランク" n
 "- [ ] 体重計測" n
 )

;; ============================================
;; 1. ログ型（記録・証拠）
;; ============================================
;; 用途: エラー解決、作業記録、トラブルシューティング

;;; 下記のコマンドを実行
;; ln -sf ~/dotfiles/2024_emacs/lib/tempel-templates.el ~/.emacs.d/templates

fundamental-mode

(log
 "# " (format-time-string "%Y%m%d-%H%M") " " p n  ;; タイトル（自動で日時挿入）
 n
 "## 状況" n                                      ;; 何が起きたか
 p n                                              ;; ← ここにカーソル移動（最初の入力位置）
 n
 "## 解決/結論" n                                 ;; どう対処したか、結果は
 p n
 n
 "## メモ" n                                      ;; 補足情報、参考URL、所要時間など
 p n
 n
 "タグ: #log")

;; ============================================
;; 2. 思考型（モヤモヤの言語化）
;; ============================================
;; 用途: 自己分析、哲学的な問い、漠然とした考えの整理
;; 例: 「やる気が出ない理由について」
;;     「転職すべきか悩んでる」
;;     「自分のキャリアをどう考えるか」
(think
  "# " (format-time-string "%Y%m%d-%H%M") " " p n
  n
  "## 問い" n                                      ;; 何について考えてるのか
  p n
  n
  "## 考えたこと" n                                ;; 思考のプロセス、連想、仮説
  p n
  n
  "## 結論（暫定）" n                              ;; 今の時点での答え（後で変わってもいい）
  p n
  n
  "## 次のアクション" n                            ;; この思考から生まれる行動は？
  p n
  n
  "タグ: #think")

;; ============================================
;; 3. 収集型（リンク・引用のストック）
;; ============================================
;; 用途: ブックマーク代わり、後で読む記事、参考資料
;; 例: 「良いEmacsの記事見つけた」
;;     「この動画後で見る」
;;     「この論文をいつか読む」
(collect
  "# " p n                                         ;; タイトル（記事名やトピック）
  n
  "URL: " p n                                      ;; リンク
  n
  "出典: " p n                                     ;; 著者、サイト名、日付など
  n
  "## 要点" n                                      ;; ざっくり何について書いてあるか
  "- " p n
  n
  "## なぜ保存したか" n                            ;; 将来の自分へのメモ
  p n
  n
  "## 後でやること" n                              ;; この情報をどう使うか
  "- " p n
  n
  "タグ: #collect")

;; ============================================
;; 4. 作戦型（計画・TODO）
;; ============================================
;; 用途: プロジェクト計画、今週のタスク、目標設定
;; 例: 「今週のミッション」
;;     「転職活動の戦略」
;;     「セキュリティ学習ロードマップ」
(mission
  "# " (format-time-string "%Y%m%d") " " p n      ;; タイトル
  n
  "期間: " p n                                     ;; いつまでに
  n
  "## 目標" n                                      ;; 何を達成したいか
  p n
  n
  "## タスク" n                                    ;; 具体的なアクション（[ ]でチェックボックス）
  "- [ ] " p n
  "- [ ] " p n
  "- [ ] " p n
  n
  "## 障害になりそうなこと" n                      ;; 予想される問題
  p n
  n
  "## 成功条件" n                                  ;; どうなったら成功か
  p n
  n
  "タグ: #mission")

;; ============================================
;; 5. スニペット型（コード・コマンドの断片）
;; ============================================
;; 用途: よく使うコマンド、コピペ用コード、自分専用チートシート
;; 例: 「Git便利コマンド集」
;;     「Emacs設定の断片」
;;     「よく忘れるLinuxコマンド」
(snippet
  "# " p n                                         ;; タイトル（例: Git便利コマンド）
  n
  "## " p n                                        ;; カテゴリ（例: ブランチ操作）
  "```" p n                                        ;; 言語名（bash, python, elisp等）
  p n                                              ;; コード本体
  "```" n
  n
  "## 説明" n                                      ;; このコードは何をするか
  p n
  n
  "## 使用例" n                                    ;; 実際の使い方
  p n
  n
  "タグ: #snippet")

;; ============================================
;; 6. 日報型（淡々とした事実）
;; ============================================
;; 用途: 生活記録、時間の使い方分析、「何もしてない」の可視化
;; 例: 毎日の行動ログ、作業時間トラッキング
;; 補足: 日記リポジトリがあるならそっちでいいかも
;;       でも「作業ログ」として使うなら有用
(daily
  "# " (format-time-string "%Y%m%d") " Daily Log" n
  n
  "## やったこと" n                                ;; 時系列で淡々と
  "- " (format-time-string "%H:%M") " " p n
  "- " p n
  n
  "## 気づき・反省" n                              ;; 良かったこと、改善点
  "- " p n
  n
  "## 明日やること" n                              ;; 次の日への引き継ぎ
  "- " p n
  n
  "## 体調・気分" n                                ;; メンタル記録（後で見返すと面白い）
  p n
  n
  "タグ: #daily")

;; ============================================
;; 7. 妄想型（実現しないかもしれないアイデア）
;; ============================================
;; 用途: 思考実験、夢物語、突飛なアイデア
;; 例: 「自分の諜報組織を作る構想」
;;     「理想のハッカー空間の設計図」
;;     「もし宝くじ当たったら」
;; 補足: 実現可能性は問わない。書くこと自体が目的。
(dream
  "# " p n                                         ;; 妄想のタイトル
  n
  "## コンセプト" n                                ;; 何を妄想してるのか
  p n
  n
  "## 具体案" n                                    ;; どんな感じか（箇条書きでOK）
  "- " p n
  n
  "## 実現するなら" n                              ;; 仮に本気でやるとしたら
  p n
  n
  "## 現実的な第一歩" n                            ;; 意外とこれが重要（妄想→行動への橋渡し）
  p n
  n
  "## ただの妄想で終わらせるかもしれないけど" n   ;; 自分への言い訳欄
  p n
  n
  "タグ: #dream")

;; ============================================
;; 8. 解剖型（他人のコード・記事の分解）
;; ============================================
;; 用途: 学習、理解の検証、他人の設定を自分のものにする
;; 例: 「このブログのDenote設定を読む」
;;     「このGitHubリポジトリの構造分析」
;;     「この記事の主張を検証する」
(analyze
  "# " p " の解剖" n                               ;; 何を分析するか
  n
  "元ネタ: " p n                                   ;; URL、書籍名、リポジトリなど
  n
  "## 概要" n                                      ;; 全体像
  p n
  n
  "## 詳細分析" n                                  ;; 行ごと、セクションごとの分解
  "### " p n                                       ;; 見出し（複数作れる）
  p n
  n
  "## 自分の環境に適用するなら" n                  ;; どう応用するか
  p n
  n
  "## 疑問点" n                                    ;; わからなかったこと（後で調べる）
  "- " p n
  n
  "## 参考になった度" n                            ;; ★★★☆☆ みたいに
  p n
  n
  "タグ: #analyze")

;;; templates ends here
